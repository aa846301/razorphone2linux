+static const struct v4l2_subdev_pad_ops s5k3h7_pad_ops = {
+	.set_fmt = s5k3h7_set_pad_format,
+	.get_fmt = v4l2_subdev_get_fmt,
+	.get_selection = s5k3h7_get_selection,
+	.enum_mbus_code = s5k3h7_enum_mbus_code,
+	.enum_frame_size = s5k3h7_enum_frame_size,
+	.enable_streams = s5k3h7_enable_streams,
+	.disable_streams = s5k3h7_disable_streams,
+};
+
+static const struct v4l2_subdev_ops s5k3h7_subdev_ops = {
+	.video = &s5k3h7_video_ops,
+	.pad = &s5k3h7_pad_ops,
+};
+
+static const struct v4l2_subdev_internal_ops s5k3h7_internal_ops = {
+	.init_state = s5k3h7_init_state,
+};
+
+static const struct media_entity_operations s5k3h7_subdev_entity_ops = {
+	.link_validate = v4l2_subdev_link_validate,
+};
+
+static int s5k3h7_identify_sensor(struct s5k3h7 *s5k3h7)
+{
+	u64 val;
+	int ret;
+
+	ret = cci_read(s5k3h7->regmap, S5K3H7_REG_CHIP_ID, &val, NULL);
+	if (ret) {
+		dev_err(s5k3h7->dev, "failed to read chip id: %d\n", ret);
+		return ret;
+	}
+
+	if (val != S5K3H7_CHIP_ID) {
+		dev_err(s5k3h7->dev, "chip id mismatch: %x!=%llx\n",
+			S5K3H7_CHIP_ID, val);
+		return -ENODEV;
+	}
+
+	return 0;
+}
+
+static int s5k3h7_check_hwcfg(struct s5k3h7 *s5k3h7)
+{
+	struct fwnode_handle *fwnode = dev_fwnode(s5k3h7->dev), *ep;
+	struct v4l2_fwnode_endpoint bus_cfg = {
+		.bus = {
+			.mipi_csi2 = {
+				.num_data_lanes = S5K3H7_DATA_LANES,
+			},
+		},
+		.bus_type = V4L2_MBUS_CSI2_DPHY,
+	};
+	unsigned long freq_bitmap;
+	int ret;
+
+	if (!fwnode)
+		return -ENODEV;
+
+	ep = fwnode_graph_get_next_endpoint(fwnode, NULL);
+	if (!ep)
+		return -EINVAL;
+
+	ret = v4l2_fwnode_endpoint_alloc_parse(ep, &bus_cfg);
+	fwnode_handle_put(ep);
+	if (ret)
+		return ret;
+
+	if (bus_cfg.bus.mipi_csi2.num_data_lanes != S5K3H7_DATA_LANES) {
+		dev_err(s5k3h7->dev, "Invalid number of data lanes: %u\n",
+			bus_cfg.bus.mipi_csi2.num_data_lanes);
+		ret = -EINVAL;
+		goto endpoint_free;
+	}
+
+	ret = v4l2_link_freq_to_bitmap(s5k3h7->dev, bus_cfg.link_frequencies,
+				       bus_cfg.nr_of_link_frequencies,
+				       s5k3h7_link_freq_menu,
+				       ARRAY_SIZE(s5k3h7_link_freq_menu),
+				       &freq_bitmap);
+
+endpoint_free:
+	v4l2_fwnode_endpoint_free(&bus_cfg);
+
+	return ret;
+}
+
+static int s5k3h7_power_on(struct device *dev)
+{
+	struct v4l2_subdev *sd = dev_get_drvdata(dev);
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+	int ret;
+
+	/* Match the factory Qualcomm power sequence: I/O, analog, digital. */
+	ret = regulator_enable(s5k3h7->supplies[2].consumer);
+	if (ret)
+		return ret;
+	usleep_range(1000, 1500);
+
+	ret = regulator_enable(s5k3h7->supplies[0].consumer);
+	if (ret)
+		goto disable_vddio;
+	usleep_range(1000, 1500);
+
+	ret = regulator_enable(s5k3h7->supplies[1].consumer);
+	if (ret)
+		goto disable_vdda;
+	usleep_range(1000, 1500);
+
+	ret = clk_prepare_enable(s5k3h7->mclk);
+	if (ret)
+		goto disable_vddd;
+	usleep_range(1000, 1500);
+
+	gpiod_set_value_cansleep(s5k3h7->reset_gpio, 0);
+	usleep_range(20 * USEC_PER_MSEC, 25 * USEC_PER_MSEC);
+
+	return 0;
+
+disable_vddd:
+	regulator_disable(s5k3h7->supplies[1].consumer);
+disable_vdda:
+	regulator_disable(s5k3h7->supplies[0].consumer);
+disable_vddio:
+	regulator_disable(s5k3h7->supplies[2].consumer);
+
+	return ret;
+}
+
+static int s5k3h7_power_off(struct device *dev)
+{
+	struct v4l2_subdev *sd = dev_get_drvdata(dev);
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+
+	gpiod_set_value_cansleep(s5k3h7->reset_gpio, 1);
+
+	clk_disable_unprepare(s5k3h7->mclk);
+
+	regulator_disable(s5k3h7->supplies[1].consumer);
+	regulator_disable(s5k3h7->supplies[0].consumer);
+	regulator_disable(s5k3h7->supplies[2].consumer);
+
+	return 0;
+}
+
+static int s5k3h7_probe(struct i2c_client *client)
+{
+	struct s5k3h7 *s5k3h7;
+	unsigned long freq;
+	unsigned int i;
+	int ret;
+
+	s5k3h7 = devm_kzalloc(&client->dev, sizeof(*s5k3h7), GFP_KERNEL);
+	if (!s5k3h7)
+		return -ENOMEM;
+
+	s5k3h7->dev = &client->dev;
+	v4l2_i2c_subdev_init(&s5k3h7->sd, client, &s5k3h7_subdev_ops);
+
+	s5k3h7->regmap = devm_cci_regmap_init_i2c(client, 16);
+	if (IS_ERR(s5k3h7->regmap))
+		return dev_err_probe(s5k3h7->dev, PTR_ERR(s5k3h7->regmap),
+				     "failed to init CCI\n");
+
+	s5k3h7->mclk = devm_v4l2_sensor_clk_get(s5k3h7->dev, NULL);
+	if (IS_ERR(s5k3h7->mclk))
+		return dev_err_probe(s5k3h7->dev, PTR_ERR(s5k3h7->mclk),
+				     "failed to get MCLK clock\n");
+
+	ret = clk_set_rate(s5k3h7->mclk, S5K3H7_MCLK_FREQ_24MHZ);
+	if (ret)
+		return dev_err_probe(s5k3h7->dev, ret,
+				     "failed to set MCLK clock rate\n");
+
+	freq = clk_get_rate(s5k3h7->mclk);
+	if (freq != S5K3H7_MCLK_FREQ_24MHZ)
+		return dev_err_probe(s5k3h7->dev, -EINVAL,
+				     "MCLK clock frequency %lu is not supported\n",
+				     freq);
+
+	ret = s5k3h7_check_hwcfg(s5k3h7);
+	if (ret)
+		return dev_err_probe(s5k3h7->dev, ret,
+				     "failed to check HW configuration\n");
+
+	s5k3h7->reset_gpio = devm_gpiod_get_optional(s5k3h7->dev, "reset",
+						     GPIOD_OUT_HIGH);
+	if (IS_ERR(s5k3h7->reset_gpio))
+		return dev_err_probe(s5k3h7->dev, PTR_ERR(s5k3h7->reset_gpio),
+				     "cannot get reset GPIO\n");
+
+	for (i = 0; i < S5K3H7_NUM_SUPPLIES; i++)
+		s5k3h7->supplies[i].supply = s5k3h7_supply_names[i];
+
+	ret = devm_regulator_bulk_get(s5k3h7->dev, S5K3H7_NUM_SUPPLIES,
+				      s5k3h7->supplies);
+	if (ret)
+		return dev_err_probe(s5k3h7->dev, ret,
+				     "failed to get supply regulators\n");
+
+	/* The sensor must be powered on to read the CHIP_ID register */
+	ret = s5k3h7_power_on(s5k3h7->dev);
+	if (ret)
+		return ret;
+
+	ret = s5k3h7_identify_sensor(s5k3h7);
+	if (ret) {
+		dev_err_probe(s5k3h7->dev, ret, "failed to find sensor\n");
+		goto power_off;
+	}
+
+	s5k3h7->mode = &s5k3h7_supported_modes[0];
+	ret = s5k3h7_init_controls(s5k3h7);
+	if (ret) {
+		dev_err_probe(s5k3h7->dev, ret, "failed to init controls\n");
+		goto power_off;
+	}
+
+	s5k3h7->sd.state_lock = s5k3h7->ctrl_handler.lock;
+	s5k3h7->sd.internal_ops = &s5k3h7_internal_ops;
+	s5k3h7->sd.flags |= V4L2_SUBDEV_FL_HAS_DEVNODE;
+	s5k3h7->sd.entity.ops = &s5k3h7_subdev_entity_ops;
+	s5k3h7->sd.entity.function = MEDIA_ENT_F_CAM_SENSOR;
+	s5k3h7->pad.flags = MEDIA_PAD_FL_SOURCE;
+
+	ret = media_entity_pads_init(&s5k3h7->sd.entity, 1, &s5k3h7->pad);
+	if (ret) {
+		dev_err_probe(s5k3h7->dev, ret,
+			      "failed to init media entity pads\n");
+		goto v4l2_ctrl_handler_free;
+	}
+
+	ret = v4l2_subdev_init_finalize(&s5k3h7->sd);
+	if (ret < 0) {
+		dev_err_probe(s5k3h7->dev, ret,
+			      "failed to init media entity pads\n");
+		goto media_entity_cleanup;
+	}
+
+	pm_runtime_set_active(s5k3h7->dev);
+	pm_runtime_enable(s5k3h7->dev);
+
+	ret = v4l2_async_register_subdev_sensor(&s5k3h7->sd);
+	if (ret < 0) {
+		dev_err_probe(s5k3h7->dev, ret,
+			      "failed to register V4L2 subdev\n");
+		goto subdev_cleanup;
+	}
+
+	pm_runtime_set_autosuspend_delay(s5k3h7->dev, 1000);
+	pm_runtime_use_autosuspend(s5k3h7->dev);
+	pm_runtime_idle(s5k3h7->dev);
+
+	return 0;
+
+subdev_cleanup:
+	v4l2_subdev_cleanup(&s5k3h7->sd);
+	pm_runtime_disable(s5k3h7->dev);
+	pm_runtime_set_suspended(s5k3h7->dev);
+
+media_entity_cleanup:
+	media_entity_cleanup(&s5k3h7->sd.entity);
+
+v4l2_ctrl_handler_free:
+	v4l2_ctrl_handler_free(s5k3h7->sd.ctrl_handler);
+
+power_off:
+	s5k3h7_power_off(s5k3h7->dev);
+
+	return ret;
+}
+
+static void s5k3h7_remove(struct i2c_client *client)
+{
+	struct v4l2_subdev *sd = i2c_get_clientdata(client);
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+
+	v4l2_async_unregister_subdev(sd);
+	v4l2_subdev_cleanup(sd);
+	media_entity_cleanup(&sd->entity);
+	v4l2_ctrl_handler_free(sd->ctrl_handler);
+	pm_runtime_disable(s5k3h7->dev);
+
+	if (!pm_runtime_status_suspended(s5k3h7->dev)) {
+		s5k3h7_power_off(s5k3h7->dev);
+		pm_runtime_set_suspended(s5k3h7->dev);
+	}
+}
+
+static const struct dev_pm_ops s5k3h7_pm_ops = {
+	SET_RUNTIME_PM_OPS(s5k3h7_power_off, s5k3h7_power_on, NULL)
+};
+
+static const struct of_device_id s5k3h7_of_match[] = {
+	{ .compatible = "samsung,s5k3h7" },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, s5k3h7_of_match);
+
+static struct i2c_driver s5k3h7_i2c_driver = {
+	.driver = {
+		.name = "s5k3h7",
+		.pm = &s5k3h7_pm_ops,
+		.of_match_table = s5k3h7_of_match,
+	},
+	.probe = s5k3h7_probe,
+	.remove = s5k3h7_remove,
+};
+
+module_i2c_driver(s5k3h7_i2c_driver);
+
+MODULE_AUTHOR("Vladimir Zapolskiy <vladimir.zapolskiy@linaro.org>");
+MODULE_DESCRIPTION("Samsung S5K3H7 image sensor driver");
+MODULE_LICENSE("GPL");
