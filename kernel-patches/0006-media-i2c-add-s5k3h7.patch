diff --git a/drivers/media/i2c/Kconfig b/drivers/media/i2c/Kconfig
index 06c46123b133..6080eab50d13 100644
--- a/drivers/media/i2c/Kconfig
+++ b/drivers/media/i2c/Kconfig
@@ -825,6 +825,16 @@ config VIDEO_S5K3M5
 	  To compile this driver as a module, choose M here: the
 	  module will be called s5k3m5.
 
+config VIDEO_S5K3H7
+	tristate "Samsung S5K3H7 sensor support"
+	select V4L2_CCI_I2C
+	help
+	  This is a V4L2 sensor driver for the Samsung S5K3H7 8MP raw
+	  camera sensor used by the Razer Phone 2 front camera.
+
+	  To compile this driver as a module, choose M here: the
+	  module will be called s5k3h7.
+
 config VIDEO_S5K5BAF
 	tristate "Samsung S5K5BAF sensor support"
 	help
