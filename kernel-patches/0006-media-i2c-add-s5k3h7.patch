+static int s5k3h7_set_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct s5k3h7 *s5k3h7 = container_of(ctrl->handler, struct s5k3h7,
+					     ctrl_handler);
+	const struct s5k3h7_mode *mode = s5k3h7->mode;
+	s64 exposure_max;
+	int ret;
+
+	/* Propagate change of current control to all related controls */
+	switch (ctrl->id) {
+	case V4L2_CID_VBLANK:
+		/* Update max exposure while meeting expected vblanking */
+		exposure_max = mode->height + ctrl->val - S5K3H7_EXPOSURE_MARGIN;
+		__v4l2_ctrl_modify_range(s5k3h7->exposure,
+					 s5k3h7->exposure->minimum,
+					 exposure_max,
+					 s5k3h7->exposure->step,
+					 s5k3h7->exposure->default_value);
+		break;
+	}
+
+	/* V4L2 controls are applied, when sensor is powered up for streaming */
+	if (!pm_runtime_get_if_active(s5k3h7->dev))
+		return 0;
+
+	switch (ctrl->id) {
+	case V4L2_CID_ANALOGUE_GAIN:
+		ret = cci_write(s5k3h7->regmap, S5K3H7_REG_AGAIN,
+				ctrl->val << S5K3H7_AGAIN_SHIFT, NULL);
+		break;
+	case V4L2_CID_EXPOSURE:
+		ret = cci_write(s5k3h7->regmap, S5K3H7_REG_EXPOSURE,
+				ctrl->val, NULL);
+		break;
+	case V4L2_CID_VBLANK:
+		ret = cci_write(s5k3h7->regmap, S5K3H7_REG_VTS,
+				ctrl->val + mode->height, NULL);
+		break;
+	case V4L2_CID_TEST_PATTERN:
+		ret = cci_write(s5k3h7->regmap, S5K3H7_REG_TEST_PATTERN,
+				ctrl->val, NULL);
+		break;
+	default:
+		ret = -EINVAL;
+		break;
+	}
+
+	pm_runtime_put(s5k3h7->dev);
+
+	return ret;
+}
+
+static const struct v4l2_ctrl_ops s5k3h7_ctrl_ops = {
+	.s_ctrl = s5k3h7_set_ctrl,
+};
+
+static inline u64 s5k3h7_freq_to_pixel_rate(const u64 freq)
+{
+	return div_u64(freq * 2 * S5K3H7_DATA_LANES, 10);
+}
+
+static int s5k3h7_init_controls(struct s5k3h7 *s5k3h7)
+{
+	struct v4l2_ctrl_handler *ctrl_hdlr = &s5k3h7->ctrl_handler;
+	const struct s5k3h7_mode *mode = s5k3h7->mode;
+	s64 pixel_rate, hblank, vblank, exposure_max;
+	struct v4l2_fwnode_device_properties props;
+	int ret;
+
+	v4l2_ctrl_handler_init(ctrl_hdlr, 9);
+
+	s5k3h7->link_freq = v4l2_ctrl_new_int_menu(ctrl_hdlr, &s5k3h7_ctrl_ops,
+					V4L2_CID_LINK_FREQ,
+					ARRAY_SIZE(s5k3h7_link_freq_menu) - 1,
+					0, s5k3h7_link_freq_menu);
+	if (s5k3h7->link_freq)
+		s5k3h7->link_freq->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	pixel_rate = s5k3h7_freq_to_pixel_rate(s5k3h7_link_freq_menu[0]);
+	s5k3h7->pixel_rate = v4l2_ctrl_new_std(ctrl_hdlr, &s5k3h7_ctrl_ops,
+					       V4L2_CID_PIXEL_RATE,
+					       0, pixel_rate, 1, pixel_rate);
+
+	hblank = mode->hts - mode->width;
+	s5k3h7->hblank = v4l2_ctrl_new_std(ctrl_hdlr, &s5k3h7_ctrl_ops,
+					   V4L2_CID_HBLANK, hblank,
+					   hblank, 1, hblank);
+	if (s5k3h7->hblank)
+		s5k3h7->hblank->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	vblank = mode->vts - mode->height;
+	s5k3h7->vblank = v4l2_ctrl_new_std(ctrl_hdlr, &s5k3h7_ctrl_ops,
+					   V4L2_CID_VBLANK, vblank,
+					   S5K3H7_VTS_MAX - mode->height, 1,
+					   vblank);
+
+	v4l2_ctrl_new_std(ctrl_hdlr, &s5k3h7_ctrl_ops, V4L2_CID_ANALOGUE_GAIN,
+			  S5K3H7_AGAIN_MIN, S5K3H7_AGAIN_MAX,
+			  S5K3H7_AGAIN_STEP, S5K3H7_AGAIN_DEFAULT);
+
+	exposure_max = mode->vts - S5K3H7_EXPOSURE_MARGIN;
+	s5k3h7->exposure = v4l2_ctrl_new_std(ctrl_hdlr, &s5k3h7_ctrl_ops,
+					     V4L2_CID_EXPOSURE,
+					     S5K3H7_EXPOSURE_MIN,
+					     exposure_max,
+					     S5K3H7_EXPOSURE_STEP,
+					     mode->exposure);
+
+	v4l2_ctrl_new_std_menu_items(ctrl_hdlr, &s5k3h7_ctrl_ops,
+				     V4L2_CID_TEST_PATTERN,
+				     ARRAY_SIZE(s5k3h7_test_pattern_menu) - 1,
+				     0, 0, s5k3h7_test_pattern_menu);
+
+
+
+	ret = v4l2_fwnode_device_parse(s5k3h7->dev, &props);
+	if (ret)
+		goto error_free_hdlr;
+
+	ret = v4l2_ctrl_new_fwnode_properties(ctrl_hdlr, &s5k3h7_ctrl_ops,
+					      &props);
+	if (ret)
+		goto error_free_hdlr;
+
+	s5k3h7->sd.ctrl_handler = ctrl_hdlr;
+
+	return 0;
+
+error_free_hdlr:
+	v4l2_ctrl_handler_free(ctrl_hdlr);
+
+	return ret;
+}
+
+static int s5k3h7_enable_streams(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *state, u32 pad,
+				 u64 streams_mask)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+	const struct s5k3h7_reg_list *reg_list = &s5k3h7->mode->reg_list;
+	int ret;
+
+	ret = pm_runtime_resume_and_get(s5k3h7->dev);
+	if (ret)
+		return ret;
+
+	cci_write(s5k3h7->regmap, CCI_REG16(0x6010), 0x0001, &ret);
+	usleep_range(3 * USEC_PER_MSEC, 4 * USEC_PER_MSEC);
+	cci_multi_reg_write(s5k3h7->regmap, s5k3h7_init_setting,
+			    ARRAY_SIZE(s5k3h7_init_setting), &ret);
+	cci_multi_reg_write(s5k3h7->regmap, reg_list->regs,
+			    reg_list->num_regs, &ret);
+	if (ret)
+		goto error;
+
+	ret = __v4l2_ctrl_handler_setup(s5k3h7->sd.ctrl_handler);
+
+	cci_write(s5k3h7->regmap, S5K3H7_REG_CTRL_MODE,
+		  S5K3H7_MODE_STREAMING, &ret);
+	if (ret)
+		goto error;
+
+	return 0;
+
+error:
+	dev_err(s5k3h7->dev, "failed to start streaming: %d\n", ret);
+	pm_runtime_put_autosuspend(s5k3h7->dev);
+
+	return ret;
+}
+
+static int s5k3h7_disable_streams(struct v4l2_subdev *sd,
+				  struct v4l2_subdev_state *state, u32 pad,
+				  u64 streams_mask)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+	int ret;
+
+	ret = cci_write(s5k3h7->regmap, S5K3H7_REG_CTRL_MODE, 0, NULL);
+	if (ret)
+		dev_err(s5k3h7->dev, "failed to stop streaming: %d\n", ret);
+
+	pm_runtime_put_autosuspend(s5k3h7->dev);
+
+	return ret;
+}
+
+static u32 s5k3h7_get_format_code(struct s5k3h7 *s5k3h7)
+{
+	return s5k3h7_mbus_formats[0];
+}
+
+static void s5k3h7_update_pad_format(struct s5k3h7 *s5k3h7,
+				     const struct s5k3h7_mode *mode,
+				     struct v4l2_mbus_framefmt *fmt)
+{
+	fmt->code = s5k3h7_get_format_code(s5k3h7);
+	fmt->width = mode->width;
+	fmt->height = mode->height;
+	fmt->field = V4L2_FIELD_NONE;
+	fmt->colorspace = V4L2_COLORSPACE_SRGB;
+	fmt->ycbcr_enc = V4L2_YCBCR_ENC_DEFAULT;
+	fmt->quantization = V4L2_QUANTIZATION_FULL_RANGE;
+	fmt->xfer_func = V4L2_XFER_FUNC_NONE;
+}
+
+static int s5k3h7_set_pad_format(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *state,
+				 struct v4l2_subdev_format *fmt)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+	s64 hblank, vblank, exposure_max;
+	const struct s5k3h7_mode *mode;
+
+	mode = v4l2_find_nearest_size(s5k3h7_supported_modes,
+				      ARRAY_SIZE(s5k3h7_supported_modes),
+				      width, height,
+				      fmt->format.width, fmt->format.height);
+
+	s5k3h7_update_pad_format(s5k3h7, mode, &fmt->format);
+
+	/* Format code could be updated with respect to flip controls */
+	if (fmt->which == V4L2_SUBDEV_FORMAT_TRY || s5k3h7->mode == mode)
+		goto set_format;
+
+	/* Update limits and set FPS and exposure to default values */
+	hblank = mode->hts - mode->width;
+	__v4l2_ctrl_modify_range(s5k3h7->hblank, hblank, hblank, 1, hblank);
+
+	vblank = mode->vts - mode->height;
+	__v4l2_ctrl_modify_range(s5k3h7->vblank, vblank,
+				 S5K3H7_VTS_MAX - mode->height, 1, vblank);
+	__v4l2_ctrl_s_ctrl(s5k3h7->vblank, vblank);
+
+	exposure_max = mode->vts - S5K3H7_EXPOSURE_MARGIN;
+	__v4l2_ctrl_modify_range(s5k3h7->exposure, S5K3H7_EXPOSURE_MIN,
+				 exposure_max, S5K3H7_EXPOSURE_STEP,
+				 mode->exposure);
+	__v4l2_ctrl_s_ctrl(s5k3h7->exposure, mode->exposure);
+
+	if (s5k3h7->sd.ctrl_handler->error)
+		return s5k3h7->sd.ctrl_handler->error;
+
+	s5k3h7->mode = mode;
+
+set_format:
+	*v4l2_subdev_state_get_format(state, 0) = fmt->format;
+
+	return 0;
+}
+
+static int s5k3h7_enum_mbus_code(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *sd_state,
+				 struct v4l2_subdev_mbus_code_enum *code)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+
+	/* Media bus code index is constant, but code formats are not */
+	if (code->index > 0)
+		return -EINVAL;
+
+	code->code = s5k3h7_get_format_code(s5k3h7);
+
+	return 0;
+}
+
+static int s5k3h7_enum_frame_size(struct v4l2_subdev *sd,
+				  struct v4l2_subdev_state *sd_state,
+				  struct v4l2_subdev_frame_size_enum *fse)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+
+	if (fse->index >= ARRAY_SIZE(s5k3h7_supported_modes))
+		return -EINVAL;
+
+	if (fse->code != s5k3h7_get_format_code(s5k3h7))
+		return -EINVAL;
+
+	fse->min_width = s5k3h7_supported_modes[fse->index].width;
+	fse->max_width = fse->min_width;
+	fse->min_height = s5k3h7_supported_modes[fse->index].height;
+	fse->max_height = fse->min_height;
+
+	return 0;
+}
+
+static int s5k3h7_get_selection(struct v4l2_subdev *sd,
+				struct v4l2_subdev_state *sd_state,
+				struct v4l2_subdev_selection *sel)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+
+	if (sel->which != V4L2_SUBDEV_FORMAT_ACTIVE)
+		return -EINVAL;
+
+	switch (sel->target) {
+	case V4L2_SEL_TGT_CROP:
+	case V4L2_SEL_TGT_CROP_BOUNDS:
+		sel->r.left = 0;
+		sel->r.top = 0;
+		sel->r.width = s5k3h7->mode->width;
+		sel->r.height = s5k3h7->mode->width;
+		return 0;
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int s5k3h7_init_state(struct v4l2_subdev *sd,
+			     struct v4l2_subdev_state *state)
+{
+	struct s5k3h7 *s5k3h7 = to_s5k3h7(sd);
+	struct v4l2_subdev_format fmt = {
+		.which = V4L2_SUBDEV_FORMAT_TRY,
+		.pad = 0,
+		.format = {
+			/* Media bus code depends on current flip controls */
+			.width = s5k3h7->mode->width,
+			.height = s5k3h7->mode->height,
+		},
+	};
+
+	s5k3h7_set_pad_format(sd, state, &fmt);
+
+	return 0;
+}
