+
+#define S5K3H7_REG_HTS			CCI_REG16(0x0342)
+#define S5K3H7_REG_X_ADDR_START		CCI_REG16(0x0344)
+#define S5K3H7_REG_Y_ADDR_START		CCI_REG16(0x0346)
+#define S5K3H7_REG_X_ADDR_END		CCI_REG16(0x0348)
+#define S5K3H7_REG_Y_ADDR_END		CCI_REG16(0x034a)
+#define S5K3H7_REG_X_OUTPUT_SIZE	CCI_REG16(0x034c)
+#define S5K3H7_REG_Y_OUTPUT_SIZE	CCI_REG16(0x034e)
+
+#define S5K3H7_REG_TEST_PATTERN		CCI_REG16(0x0600)
+
+#define to_s5k3h7(_sd)			container_of(_sd, struct s5k3h7, sd)
+
+static const s64 s5k3h7_link_freq_menu[] = {
+	S5K3H7_LINK_FREQ_330MHZ,
+};
+
+/* Factory RAW10 Bayer order. */
+static const u32 s5k3h7_mbus_formats[] = {
+	MEDIA_BUS_FMT_SGRBG10_1X10,
+};
+
+struct s5k3h7_reg_list {
+	const struct cci_reg_sequence *regs;
+	unsigned int num_regs;
+};
+
+struct s5k3h7_mode {
+	u32 width;			/* Frame width in pixels */
+	u32 height;			/* Frame height in pixels */
+	u32 hts;			/* Horizontal timing size */
+	u32 vts;			/* Default vertical timing size */
+	u32 exposure;			/* Default exposure value */
+
+	const struct s5k3h7_reg_list reg_list;	/* Sensor register setting */
+};
+
+static const char * const s5k3h7_test_pattern_menu[] = {
+	"Disabled",
+	"Solid colour",
+	"Colour bars",
+	"Fade to grey colour bars",
+	"PN9",
+};
+
+static const char * const s5k3h7_supply_names[] = {
+	"vdda",		/* Analog power */
+	"vddd",		/* Digital core power */
+	"vddio",	/* Digital I/O power */
+};
+
+#define S5K3H7_NUM_SUPPLIES	ARRAY_SIZE(s5k3h7_supply_names)
+
+struct s5k3h7 {
+	struct device *dev;
+	struct regmap *regmap;
+	struct clk *mclk;
+	struct gpio_desc *reset_gpio;
+	struct regulator_bulk_data supplies[S5K3H7_NUM_SUPPLIES];
+
+	struct v4l2_subdev sd;
+	struct media_pad pad;
+
+	struct v4l2_ctrl_handler ctrl_handler;
+	struct v4l2_ctrl *link_freq;
+	struct v4l2_ctrl *pixel_rate;
+	struct v4l2_ctrl *hblank;
+	struct v4l2_ctrl *vblank;
+	struct v4l2_ctrl *exposure;
+
+	const struct s5k3h7_mode *mode;
+};
