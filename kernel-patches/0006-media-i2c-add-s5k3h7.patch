+#define S5K3H7_LINK_FREQ_330MHZ		(330000ULL * HZ_PER_KHZ)
+#define S5K3H7_MCLK_FREQ_24MHZ		(24 * HZ_PER_MHZ)
+#define S5K3H7_DATA_LANES		4
+
+/* Register map is similar to MIPI CCS compliant camera sensors */
+#define S5K3H7_REG_CHIP_ID		CCI_REG16(0x0000)
+#define S5K3H7_CHIP_ID			0x3087
+
+/* Streaming control */
+#define S5K3H7_REG_CTRL_MODE		CCI_REG16(0x0100)
+#define S5K3H7_MODE_STREAMING		BIT(8)
+
+#define S5K3H7_REG_EXPOSURE		CCI_REG16(0x0202)
