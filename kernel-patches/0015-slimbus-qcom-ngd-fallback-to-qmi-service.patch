diff --git a/drivers/slimbus/qcom-ngd-ctrl.c b/drivers/slimbus/qcom-ngd-ctrl.c
index 1ed6be6e8..f3fba2585 100644
--- a/drivers/slimbus/qcom-ngd-ctrl.c
+++ b/drivers/slimbus/qcom-ngd-ctrl.c
@@ -1374,6 +1374,12 @@ static int qcom_slim_ngd_qmi_new_server(struct qmi_handle *hdl,
 	qmi->svc_info.sq_port = service->port;
 
 	complete(&ctrl->qmi_up);
+	/*
+	 * Some ADSP firmware, including the Razer Phone 2 factory image, does
+	 * not publish avs/audio through PDR. Its downstream driver starts the
+	 * domain directly from QMI_SERVER_ARRIVE, so mirror that fallback here.
+	 */
+	schedule_work(&ctrl->ngd_up_work);
 
 	return 0;
 }
@@ -1461,7 +1467,8 @@ static void qcom_slim_ngd_up_worker(struct work_struct *work)
 	}
 
 	mutex_lock(&ctrl->ssr_lock);
-	qcom_slim_ngd_enable(ctrl, true);
+	if (ctrl->state == QCOM_SLIM_NGD_CTRL_DOWN)
+		qcom_slim_ngd_enable(ctrl, true);
 	mutex_unlock(&ctrl->ssr_lock);
 }
 
@@ -1574,26 +1581,24 @@ static int qcom_slim_ngd_probe(struct platform_device *pdev)
 	pm_runtime_set_suspended(dev);
 	pm_runtime_enable(dev);
 	pm_runtime_get_noresume(dev);
-	ret = qcom_slim_ngd_qmi_svc_event_init(ctrl);
-	if (ret) {
-		dev_err(&pdev->dev, "QMI service registration failed:%d", ret);
-		return ret;
-	}
-
 	INIT_WORK(&ctrl->m_work, qcom_slim_ngd_master_worker);
 	INIT_WORK(&ctrl->ngd_up_work, qcom_slim_ngd_up_worker);
 	ctrl->mwq = create_singlethread_workqueue("ngd_master");
 	if (!ctrl->mwq) {
 		dev_err(&pdev->dev, "Failed to start master worker\n");
-		ret = -ENOMEM;
-		goto wq_err;
+		return -ENOMEM;
+	}
+
+	ret = qcom_slim_ngd_qmi_svc_event_init(ctrl);
+	if (ret) {
+		dev_err(&pdev->dev, "QMI service registration failed:%d", ret);
+		goto qmi_err;
 	}
 
 	return 0;
-wq_err:
-	qcom_slim_ngd_qmi_svc_event_deinit(&ctrl->qmi);
-	if (ctrl->mwq)
-		destroy_workqueue(ctrl->mwq);
+qmi_err:
+	destroy_workqueue(ctrl->mwq);
+	ctrl->mwq = NULL;
 
 	return ret;
 }
@@ -1651,27 +1656,23 @@ static int qcom_slim_ngd_ctrl_probe(struct platform_device *pdev)
 
 	ctrl->pdr = pdr_handle_alloc(slim_pd_status, ctrl);
 	if (IS_ERR(ctrl->pdr)) {
-		ret = dev_err_probe(dev, PTR_ERR(ctrl->pdr),
-				    "Failed to init PDR handle\n");
-		goto err_pdr_alloc;
-	}
-
-	pds = pdr_add_lookup(ctrl->pdr, "avs/audio", "msm/adsp/audio_pd");
-	if (IS_ERR(pds) && PTR_ERR(pds) != -EALREADY) {
-		ret = dev_err_probe(dev, PTR_ERR(pds), "pdr add lookup failed\n");
-		goto err_pdr_lookup;
+		dev_warn(dev, "PDR unavailable, falling back to SSR/QMI: %ld\n",
+			 PTR_ERR(ctrl->pdr));
+		ctrl->pdr = NULL;
+	} else {
+		pds = pdr_add_lookup(ctrl->pdr, "avs/audio",
+				     "msm/adsp/audio_pd");
+		if (IS_ERR(pds) && PTR_ERR(pds) != -EALREADY) {
+			dev_warn(dev,
+				 "audio PDR lookup failed, falling back to SSR/QMI: %ld\n",
+				 PTR_ERR(pds));
+			pdr_handle_release(ctrl->pdr);
+			ctrl->pdr = NULL;
+		}
 	}
 
 	platform_driver_register(&qcom_slim_ngd_driver);
 	return of_qcom_slim_ngd_register(dev, ctrl);
-
-err_pdr_alloc:
-	qcom_unregister_ssr_notifier(ctrl->notifier, &ctrl->nb);
-
-err_pdr_lookup:
-	pdr_handle_release(ctrl->pdr);
-
-	return ret;
 }
 
 static void qcom_slim_ngd_ctrl_remove(struct platform_device *pdev)
@@ -1684,7 +1685,8 @@ static void qcom_slim_ngd_remove(struct platform_device *pdev)
 	struct qcom_slim_ngd_ctrl *ctrl = platform_get_drvdata(pdev);
 
 	pm_runtime_disable(&pdev->dev);
-	pdr_handle_release(ctrl->pdr);
+	if (ctrl->pdr)
+		pdr_handle_release(ctrl->pdr);
 	qcom_unregister_ssr_notifier(ctrl->notifier, &ctrl->nb);
 	qcom_slim_ngd_enable(ctrl, false);
 	qcom_slim_ngd_exit_dma(ctrl);
