KERNEL_REPO=https://gitlab.com/sdm845-mainline/linux.git
KERNEL_BRANCH="${RAZER_KERNEL_BRANCH_OVERRIDE:-sdm845/7.1-dev}"
# Override for cross-version builds (e.g. the 6.16 pstore-reader boot).
KERNEL_COMMIT="${RAZER_KERNEL_COMMIT_OVERRIDE:-85f1df2a4ec71d7a91dd95a7a49f889d1595ffa8}"
# Optional in-repository kernel source. If this directory exists, CI/local
# setup uses it instead of fetching KERNEL_REPO.
KERNEL_LOCAL_DIR="${RAZER_KERNEL_LOCAL_DIR:-${PROJECT_DIR:-$(pwd)}/kernel-source/linux}"
