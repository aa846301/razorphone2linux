# Razer Phone 2 (aura) canonical kernel config fragment.
#
# Apply this fragment from scripts/02-build-kernel.sh only. Do not keep
# alternate config fragments in WSL home or ad-hoc rebuild scripts.

# Kernel release suffix. A dirty suffix is expected while device support is
# under active development; keep this stable so boot/rootfs module directories
# do not drift between builds.
CONFIG_LOCALVERSION="-sdm845"
# Do NOT use CC_OPTIMIZE_FOR_SIZE: -Os kernels (both 6.16 and 7.1) freeze
# at the boot splash on this device/toolchain with zero output, tested
# 2026-07-06. Stay under the ~16MB ABL cliff by trimming non-QCOM vendor
# drivers instead.
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
# Persistent crash capture: the DTS carves a ramoops region at 0xac300000.
# Console output survives a warm reset there, so an early-hanging kernel
# (7.1 bring-up) can be autopsied from the next boot's /sys/fs/pstore.
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
CONFIG_PSTORE_CONSOLE=y
# The kernel checkout is a generated workspace with repo-owned DTS/patches.
# Keep the release reproducible instead of appending git's "-dirty" marker.
# CONFIG_LOCALVERSION_AUTO is not set

# Platform
CONFIG_ARCH_QCOM=y

# Display path: keep simpledrm/fbdev usable first. Full MSM/NT36830 remains
# modular so it does not take over the bootloader framebuffer during bring-up.
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM_MSM=m
CONFIG_DRM_PANEL_NOVATEK_NT36830=m
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_DSC_HELPER=y
CONFIG_DRM_PANEL_BACKLIGHT_QUIRKS=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_QCOM_WLED=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FB=y

# Touchscreen
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_RMI4_CORE=y
CONFIG_RMI4_I2C=y
CONFIG_RMI4_F01=y
CONFIG_RMI4_F12=y

# WiFi / Bluetooth
# June truth (IKCONFIG extracted from the known-good kernel): the WiFi stack
# is modular with debug enabled. Keeping it =m also keeps the kernel Image
# well under the ABL's ~16MB tolerance (a builtin build at 16.66MB dropped
# straight to the bootloader).
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_ATH10K=m
CONFIG_ATH10K_SNOC=m
CONFIG_ATH10K_DEBUG=y
CONFIG_ATH10K_DEBUGFS=y
CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_QCA=y

# USB gadget and serial debug
CONFIG_USB=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_G_SERIAL=m
CONFIG_USB_ACM=y
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_GENERIC=y

# USB / UFS PHYs
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QUSB2=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_UFS=y

# Storage
CONFIG_SCSI=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y

# Qualcomm platform support
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SOCINFO=y
CONFIG_QCOM_PDC=y
CONFIG_RESET_QCOM_PDC=y
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_SDM845_LLCC=y
CONFIG_PINCTRL_SDM845=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_SDM845=y

# QUP / console
CONFIG_I2C=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_SPI=y
CONFIG_SPI_QCOM_GENI=y
CONFIG_SERIAL_MSM=y
CONFIG_SERIAL_MSM_CONSOLE=y

# Power / PMIC
CONFIG_REGULATOR=y
CONFIG_REGULATOR_QCOM_SPMI=y
CONFIG_MFD_QCOM_RPM=y
CONFIG_SPMI=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y
# PMI8998 uses the SMB2 charger and Gen3 fuel gauge, not the older PM8941 SMBB.
# CONFIG_CHARGER_QCOM_SMBB is not set
CONFIG_CHARGER_QCOM_SMB2=y
CONFIG_BATTERY_PMI8998_FG=y
CONFIG_QCOM_SPMI_RRADC=y

# Filesystems and initramfs
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_WIRELESS=y
CONFIG_RFKILL=y

# Modules
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# Remoteproc / QRTR / modem-WiFi chain
#
# 2026-07-03 final ground truth (IKCONFIG extracted from the known-good June
# kernel + diffconfig): June ran this chain as MODULES — identical to this
# config apart from LOCALVERSION_AUTO. The ~30s reset regression on fresh
# rootfs is NOT a kernel config issue: it is boot-ordering (modules slammed
# in at ~5s before rmtfs/userspace is ready, versus ~25s on the June image).
# The fix lives in the rootfs staged bring-up (razer-wifi-ready), not here.
CONFIG_REMOTEPROC=y
CONFIG_REMOTEPROC_CDEV=y
CONFIG_QCOM_Q6V5_COMMON=m
CONFIG_QCOM_Q6V5_MSS=m
CONFIG_QCOM_Q6V5_ADSP=m
CONFIG_QCOM_Q6V5_PAS=m
# CONFIG_QCOM_Q6V5_WCSS is not set
CONFIG_QCOM_WCNSS_PIL=m
CONFIG_QCOM_RPROC_COMMON=m
CONFIG_QCOM_SYSMON=m
CONFIG_QCOM_AOSS_QMP=y
CONFIG_RESET_QCOM_AOSS=y
CONFIG_RPMSG=y
CONFIG_RPMSG_QCOM_SMD=y
CONFIG_RPMSG_QCOM_GLINK=y
CONFIG_RPMSG_QCOM_GLINK_RPM=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=m
CONFIG_QRTR=m
CONFIG_QRTR_SMD=m
CONFIG_QRTR_TUN=m
CONFIG_QRTR_MHI=m
CONFIG_MHI_BUS=m
CONFIG_QCOM_PIL_INFO=m
CONFIG_QCOM_IPA=m
# Use userspace pd-mapper on SDM845. The postmarketOS SDM845 config fragment
# disables the in-kernel mapper because it can introduce race conditions.
# CONFIG_QCOM_PD_MAPPER is not set
CONFIG_QCOM_PDR_HELPERS=m
CONFIG_QCOM_PDR_MSG=m
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_MDT_LOADER=m
CONFIG_QCOM_QMI_HELPERS=m
CONFIG_QCOM_WCNSS_CTRL=y

# Audio / LEDs
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_QCOM=y
CONFIG_SND_SOC_SDM845=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_CLASS_FLASH=y
CONFIG_LEDS_QCOM_FLASH=y
CONFIG_LEDS_QCOM_LPG=y
CONFIG_LEDS_PWM=y
CONFIG_BACKLIGHT_PWM=y
CONFIG_PWM=y
CONFIG_PWM_QCOM_LPG=y

# Basic userspace requirements
CONFIG_PRINTK=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_CGROUPS=y
CONFIG_INOTIFY_USER=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y

# Persistent crash logs
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_RAM=y

# Non-QCOM vendor platforms (2026-07-06): the base defconfig enables ~40
# other vendors' SoC support as builtin, which is what pushes 7.1-era
# kernels over the ~16MB ABL cliff. This device is SDM845 only.
# CONFIG_ARCH_ACTIONS is not set
# CONFIG_ARCH_AIROHA is not set
# CONFIG_ARCH_SUNXI is not set
# CONFIG_ARCH_ALPINE is not set
# CONFIG_ARCH_APPLE is not set
# CONFIG_ARCH_BCM is not set
# CONFIG_ARCH_BCM2835 is not set
# CONFIG_ARCH_BCM_IPROC is not set
